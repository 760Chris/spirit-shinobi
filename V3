<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Spirit Shinobi V3</title>
  <meta name="theme-color" content="#0f172a" />
  <style>
    :root{
      --bg:#020617;
      --panel:#111827;
      --panel2:#0b1220;
      --line:#334155;
      --text:#e5e7eb;
      --muted:#94a3b8;
      --green:#22c55e;
      --blue:#38bdf8;
      --red:#f87171;
      --yellow:#facc15;
      --grass:#166534;
      --path:#8b5e34;
      --wall:#374151;
      --water:#2563eb;
      --npc:#c084fc;
      --trainer:#60a5fa;
      --heal:#10b981;
      --shop:#f59e0b;
      --sensei:#f472b6;
    }
    *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
    html,body{
      margin:0;padding:0;background:linear-gradient(180deg,#020617,#111827);
      color:var(--text);font-family:Arial,Helvetica,sans-serif
    }
    body{min-height:100vh}
    .wrap{max-width:1320px;margin:0 auto;padding:16px}
    .card{
      background:rgba(17,24,39,.97);border:1px solid var(--line);border-radius:18px;
      padding:16px;box-shadow:0 10px 30px rgba(0,0,0,.24);margin-bottom:16px
    }
    .inset{background:var(--panel2)}
    .hidden{display:none !important}
    .hero{text-align:center}
    .sub{color:var(--muted)}
    .row{display:flex;gap:10px;flex-wrap:wrap}
    .top-gap{margin-top:12px}
    .starter-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .starter{background:var(--panel2);border:1px solid #243146;border-radius:14px;padding:14px}
    .badge{display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:700;margin-bottom:8px}
    .fire{background:rgba(248,113,113,.14);color:#fb7185}
    .waterb{background:rgba(56,189,248,.14);color:#38bdf8}
    .lightning{background:rgba(250,204,21,.14);color:#facc15}
    button{
      border:none;border-radius:12px;padding:12px 14px;background:#2563eb;color:#fff;
      font-weight:700;cursor:pointer;font-size:15px
    }
    button.secondary{background:#475569}
    button.good{background:#16a34a}
    button.warn{background:#d97706}
    button.danger{background:#dc2626}
    button:disabled{opacity:.55;cursor:not-allowed}
    .game-grid{display:grid;grid-template-columns:minmax(300px,720px) 1fr;gap:16px}
    #gameCanvas{
      width:100%;max-width:672px;height:auto;display:block;margin:0 auto;
      image-rendering:pixelated;border:2px solid #475569;border-radius:14px;background:#000;
      touch-action:manipulation
    }
    .touch-controls{
      width:220px;margin:14px auto 0;display:grid;grid-template-columns:repeat(3,1fr);gap:10px
    }
    .touch-btn{min-height:54px;font-size:22px;border-radius:14px}
    .hint{color:var(--muted);text-align:center;margin-top:10px}
    .stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:12px 0}
    .log,.dialog-text{
      min-height:120px;max-height:260px;overflow:auto;white-space:pre-wrap;line-height:1.45;
      background:#07101d;border:1px solid #1f2d42;border-radius:12px;padding:12px
    }
    .meter{height:12px;background:#1e293b;border-radius:999px;overflow:hidden;margin:6px 0 10px}
    .fill{height:100%;background:var(--green)}
    .fill.chakra{background:var(--blue)}
    .fill.enemy{background:var(--red)}
    .small{font-size:13px;color:var(--muted)}
    .battle-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0}
    .quest-done{color:#4ade80;font-weight:700}
    .quest-open{color:#facc15;font-weight:700}
    .shop-item{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px;border:1px solid #243146;border-radius:12px;background:#07101d;margin-bottom:10px}
    @media (max-width: 900px){
      .starter-grid,.stats-grid,.game-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
<div class="wrap">
  <header class="card hero">
    <h1>Spirit Shinobi V3</h1>
    <p class="sub">Naruto-inspired monster battler prototype with quests, shop, save/load, and mobile controls.</p>
  </header>

  <section id="starterPanel" class="card">
    <h2>Choose Your Starter</h2>
    <div class="starter-grid">
      <article class="starter">
        <h3>Ember Wolf</h3>
        <span class="badge fire">Fire</span>
        <p>Fast attacker with Flame Bite.</p>
        <button data-starter="Ember Wolf">Choose</button>
      </article>
      <article class="starter">
        <h3>Aqua Serpent</h3>
        <span class="badge waterb">Water</span>
        <p>Bulky defender with Water Pulse.</p>
        <button data-starter="Aqua Serpent">Choose</button>
      </article>
      <article class="starter">
        <h3>Volt Hawk</h3>
        <span class="badge lightning">Lightning</span>
        <p>High speed burst damage.</p>
        <button data-starter="Volt Hawk">Choose</button>
      </article>
    </div>
  </section>

  <section id="gameUI" class="hidden">
    <div class="game-grid">
      <div class="card">
        <canvas id="gameCanvas" width="672" height="672"></canvas>
        <div class="touch-controls">
          <div></div><button id="upBtn" class="touch-btn">▲</button><div></div>
          <button id="leftBtn" class="touch-btn">◀</button>
          <button id="downBtn" class="touch-btn">▼</button>
          <button id="rightBtn" class="touch-btn">▶</button>
        </div>
        <p class="hint">Move with arrow keys, WASD, or touch buttons. Stand next to NPCs and press Space or Enter.</p>
      </div>

      <div>
        <section id="worldPanel" class="card">
          <h2>World</h2>
          <div class="row">
            <button id="partyOpenBtn">Party</button>
            <button id="saveBtn" class="secondary">Save</button>
            <button id="loadBtn" class="secondary">Load</button>
            <button id="resetBtn" class="danger">Reset</button>
          </div>

          <div class="stats-grid">
            <div class="card inset">
              <h3>Active Beast</h3>
              <div id="activeStats"></div>
            </div>
            <div class="card inset">
              <h3>Progress</h3>
              <div id="progressStats"></div>
            </div>
          </div>

          <div class="card inset">
            <h3>Quest Tracker</h3>
            <div id="questStats"></div>
          </div>

          <h3>World Log</h3>
          <div id="log" class="log"></div>
        </section>

        <section id="battlePanel" class="card hidden">
          <h2>Battle</h2>
          <div class="stats-grid">
            <div class="card inset"><div id="playerBattleStats"></div></div>
            <div class="card inset"><div id="enemyBattleStats"></div></div>
          </div>
          <div id="battleActions" class="battle-actions"></div>
          <h3>Battle Log</h3>
          <div id="battleLog" class="log"></div>
        </section>

        <section id="partyPanel" class="card hidden">
          <h2>Party</h2>
          <div id="partyList"></div>
          <div class="row top-gap">
            <button id="partyCloseBtn" class="secondary">Close</button>
          </div>
        </section>

        <section id="dialogPanel" class="card hidden">
          <h2 id="dialogName">NPC</h2>
          <div id="dialogText" class="dialog-text"></div>
          <div id="dialogChoices" class="row top-gap"></div>
          <div class="row top-gap">
            <button id="dialogCloseBtn" class="secondary">Close</button>
          </div>
        </section>
      </div>
    </div>
  </section>
</div>

<script>
const TILE = 48;
const MAP_W = 14;
const MAP_H = 14;
const SAVE_KEY = "spirit_shinobi_v3_save";

const map = [
  "##############",
  "#..N.....T...#",
  "#..gggg......#",
  "#..g..g......#",
  "#..g..g..M...#",
  "#.....P......#",
  "#............#",
  "#..gggg..H...#",
  "#..g..g......#",
  "#..g..g..S...#",
  "#..gggg......#",
  "#...........R#",
  "#............#",
  "##############"
];

const creaturesData = {
  "Ember Wolf": {type:"Fire", maxHp:45,maxChakra:30,attack:55,defense:35,speed:60,evolvesTo:"Blaze Wolf",evolveLevel:10,moves:[{name:"Flame Bite",power:40,cost:5,type:"Fire",effect:null},{name:"Focus",power:0,cost:3,type:"Neutral",effect:"buff_attack"}]},
  "Aqua Serpent": {type:"Water", maxHp:50,maxChakra:40,attack:45,defense:50,speed:35,evolvesTo:"Tide Serpent",evolveLevel:10,moves:[{name:"Water Pulse",power:35,cost:4,type:"Water",effect:"stun20"},{name:"Coil",power:0,cost:3,type:"Neutral",effect:"buff_defense"}]},
  "Volt Hawk": {type:"Lightning", maxHp:40,maxChakra:35,attack:50,defense:30,speed:70,evolvesTo:"Storm Hawk",evolveLevel:10,moves:[{name:"Thunder Peck",power:45,cost:6,type:"Lightning",effect:"crit20"},{name:"Focus",power:0,cost:3,type:"Neutral",effect:"buff_speed"}]},
  "Mist Fox": {type:"Water", maxHp:38,maxChakra:28,attack:40,defense:28,speed:58,moves:[{name:"Mist Claw",power:32,cost:4,type:"Water",effect:null},{name:"Blur",power:0,cost:3,type:"Neutral",effect:"buff_speed"}]},
  "Stone Ape": {type:"Earth", maxHp:54,maxChakra:20,attack:48,defense:55,speed:22,moves:[{name:"Rock Fist",power:38,cost:4,type:"Earth",effect:null},{name:"Guard",power:0,cost:3,type:"Neutral",effect:"buff_defense"}]},
  "Spark Beetle": {type:"Lightning", maxHp:34,maxChakra:25,attack:36,defense:25,speed:66,moves:[{name:"Zap Sting",power:30,cost:4,type:"Lightning",effect:null},{name:"Charge",power:0,cost:3,type:"Neutral",effect:"buff_attack"}]},
  "Wind Hare": {type:"Wind", maxHp:36,maxChakra:30,attack:34,defense:26,speed:72,moves:[{name:"Gale Kick",power:33,cost:4,type:"Wind",effect:null},{name:"Rush",power:0,cost:3,type:"Neutral",effect:"buff_speed"}]},
  "Ash Toad": {type:"Fire", maxHp:42,maxChakra:32,attack:41,defense:38,speed:39,moves:[{name:"Cinder Pop",power:34,cost:4,type:"Fire",effect:null},{name:"Focus",power:0,cost:3,type:"Neutral",effect:"buff_attack"}]},
  "Blaze Wolf": {type:"Fire", maxHp:68,maxChakra:42,attack:76,defense:52,speed:80,moves:[{name:"Inferno Fang",power:58,cost:7,type:"Fire",effect:null},{name:"Rage Focus",power:0,cost:4,type:"Neutral",effect:"buff_attack"}]},
  "Tide Serpent": {type:"Water", maxHp:72,maxChakra:52,attack:62,defense:72,speed:48,moves:[{name:"Tidal Crash",power:55,cost:7,type:"Water",effect:"stun20"},{name:"Iron Coil",power:0,cost:4,type:"Neutral",effect:"buff_defense"}]},
  "Storm Hawk": {type:"Lightning", maxHp:62,maxChakra:46,attack:70,defense:44,speed:92,moves:[{name:"Sky Lance",power:60,cost:8,type:"Lightning",effect:"crit20"},{name:"Quick Focus",power:0,cost:4,type:"Neutral",effect:"buff_speed"}]}
};

const typeChart = {
  Fire:{strong:["Wind"],weak:["Water"]},
  Water:{strong:["Fire"],weak:["Lightning"]},
  Lightning:{strong:["Water"],weak:["Earth"]},
  Earth:{strong:["Lightning"],weak:["Wind"]},
  Wind:{strong:["Earth"],weak:["Fire"]},
  Neutral:{strong:[],weak:[]}
};

const npcData = {
  N:{name:"Sensei Riku", text:"Welcome, shinobi. Catch one Chakra Beast and defeat the trial trainer.", choices:["Quest","Heal"]},
  M:{name:"Merchant Aoi", text:"Need supplies? I sell Seal Tags and Potions.", choices:["Shop"]},
  H:{name:"Shrine Keeper", text:"The healing shrine restores your party.", choices:["Heal"]},
  S:{name:"Archivist Nami", text:"I keep records. Saving is wise before a hard fight.", choices:["Save","Load"]},
  R:{name:"Rival Kento", text:"You made it this far? Let’s see if your contract is strong enough.", choices:["Battle"]}
};

let state = {
  started:false,
  mode:"world",
  player:{x:5,y:5},
  party:[],
  activeIndex:0,
  captured:0,
  gold:100,
  sealTags:5,
  potions:2,
  trainerDefeated:false,
  rivalDefeated:false,
  quests:{talkSensei:false,catchOne:false,beatTrainer:false,beatRival:false},
  battle:null,
  stunned:false,
  enemyStunned:false
};

const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

function deepClone(obj){ return JSON.parse(JSON.stringify(obj)); }

function createCreature(name, level=5){
  const base = creaturesData[name];
  return {
    name,type:base.type,level,exp:0,
    maxHp: base.maxHp + (level-5)*4,
    hp: base.maxHp + (level-5)*4,
    maxChakra: base.maxChakra + (level-5)*2,
    chakra: base.maxChakra + (level-5)*2,
    attack: base.attack + (level-5)*2,
    defense: base.defense + (level-5)*2,
    speed: base.speed + (level-5)*2,
    moves: deepClone(base.moves),
    buffs:{attack:0,defense:0,speed:0}
  };
}

function chooseStarter(name){
  state.party = [createCreature(name,5)];
  state.started = true;
  hide("starterPanel");
  show("gameUI");
  log("You formed a contract with " + name + ".\nTalk to Sensei Riku, catch a beast, then defeat the trial trainer.");
  renderAll();
}

document.querySelectorAll("[data-starter]").forEach(btn=>{
  btn.addEventListener("click",()=>chooseStarter(btn.dataset.starter));
});

["up","down","left","right"].forEach(dir=>{
  document.getElementById(dir+"Btn").addEventListener("click",()=>{
    if(dir==="up") movePlayer(0,-1);
    if(dir==="down") movePlayer(0,1);
    if(dir==="left") movePlayer(-1,0);
    if(dir==="right") movePlayer(1,0);
  });
});

document.getElementById("partyOpenBtn").onclick = showParty;
document.getElementById("partyCloseBtn").onclick = closeParty;
document.getElementById("saveBtn").onclick = saveGame;
document.getElementById("loadBtn").onclick = loadGame;
document.getElementById("resetBtn").onclick = ()=>location.reload();
document.getElementById("dialogCloseBtn").onclick = closeDialog;

document.addEventListener("keydown",(e)=>{
  const k = e.key.toLowerCase();
  if(["arrowup","w"].includes(k)) movePlayer(0,-1);
  else if(["arrowdown","s"].includes(k)) movePlayer(0,1);
  else if(["arrowleft","a"].includes(k)) movePlayer(-1,0);
  else if(["arrowright","d"].includes(k)) movePlayer(1,0);
  else if([" ","enter"].includes(k)) interact();
});

function show(id){ document.getElementById(id).classList.remove("hidden"); }
function hide(id){ document.getElementById(id).classList.add("hidden"); }

function activeCreature(){ return state.party[state.activeIndex]; }

function log(text){
  const el=document.getElementById("log");
  el.textContent = text + "\n\n" + el.textContent;
}
function battleLog(text){
  const el=document.getElementById("battleLog");
  el.textContent = text + "\n\n" + el.textContent;
}

function tileAt(x,y){ return map[y][x]; }
function isWalkable(x,y){ return tileAt(x,y) !== "#"; }

function drawMap(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  for(let y=0;y<MAP_H;y++){
    for(let x=0;x<MAP_W;x++){
      const t = tileAt(x,y);
      if(t==="#") ctx.fillStyle=getCss("--wall");
      else if(t==="g") ctx.fillStyle=getCss("--grass");
      else ctx.fillStyle=getCss("--path");
      ctx.fillRect(x*TILE,y*TILE,TILE,TILE);
      ctx.strokeStyle="rgba(255,255,255,.08)";
      ctx.strokeRect(x*TILE,y*TILE,TILE,TILE);

      if(t==="N"){ drawMarker(x,y,getCss("--sensei")); }
      if(t==="M"){ drawMarker(x,y,getCss("--shop")); }
      if(t==="H"){ drawMarker(x,y,getCss("--heal")); }
      if(t==="S"){ drawMarker(x,y,getCss("--npc")); }
      if(t==="T" && !state.trainerDefeated){ drawMarker(x,y,getCss("--trainer")); }
      if(t==="R" && !state.rivalDefeated){ drawMarker(x,y,"#f43f5e"); }
    }
  }
  ctx.fillStyle="#fff";
  ctx.fillRect(state.player.x*TILE+12,state.player.y*TILE+12,24,24);
}

function drawMarker(x,y,color){
  ctx.fillStyle=color;
  ctx.fillRect(x*TILE+12,y*TILE+12,24,24);
}

function getCss(name){ return getComputedStyle(document.documentElement).getPropertyValue(name).trim(); }

function movePlayer(dx,dy){
  if(state.mode!=="world" || !state.started) return;
  const nx=state.player.x+dx, ny=state.player.y+dy;
  if(!isWalkable(nx,ny)) return;
  state.player.x=nx; state.player.y=ny;
  renderAll();
  const t=tileAt(nx,ny);
  if(t==="g" && Math.random()<0.23) startWildBattle();
}

function interact(){
  if(state.mode!=="world") return;
  const dirs=[[0,-1],[0,1],[-1,0],[1,0],[0,0]];
  for(const [dx,dy] of dirs){
    const x=state.player.x+dx, y=state.player.y+dy;
    const t=tileAt(x,y);
    if(npcData[t]) return openDialog(t);
    if(t==="T" && !state.trainerDefeated) return startTrainerBattle();
    if(t==="R" && !state.rivalDefeated) return startRivalBattle();
  }
}

function openDialog(code){
  const npc=npcData[code];
  show("dialogPanel");
  hide("worldPanel"); hide("partyPanel"); hide("battlePanel");
  document.getElementById("dialogName").textContent=npc.name;
  document.getElementById("dialogText").textContent=npc.text;
  const choices=document.getElementById("dialogChoices");
  choices.innerHTML="";
  npc.choices.forEach(choice=>{
    const b=document.createElement("button");
    b.textContent=choice;
    b.onclick=()=>handleDialogChoice(code,choice);
    choices.appendChild(b);
  });
  if(code==="N") state.quests.talkSensei=true;
  renderAll();
}

function closeDialog(){
  hide("dialogPanel");
  if(state.mode==="battle") show("battlePanel");
  else show("worldPanel");
}

function handleDialogChoice(code,choice){
  if(choice==="Heal"){
    healParty(true);
    document.getElementById("dialogText").textContent = npcData[code].name + " restored your party.";
  } else if(choice==="Save"){
    saveGame();
    document.getElementById("dialogText").textContent = "Progress saved.";
  } else if(choice==="Load"){
    loadGame();
    closeDialog();
  } else if(choice==="Quest"){
    document.getElementById("dialogText").textContent = "Current mission:\n1. Catch one Chakra Beast.\n2. Defeat the trial trainer.\n3. Defeat your rival.";
  } else if(choice==="Shop"){
    openShop();
  } else if(choice==="Battle"){
    closeDialog();
    startRivalBattle();
  }
}

function openShop(){
  const text=document.getElementById("dialogText");
  const choices=document.getElementById("dialogChoices");
  text.textContent="Choose an item.\nSeal Tag: 25 gold\nPotion: 20 gold";
  choices.innerHTML="";

  const buySeal=document.createElement("button");
  buySeal.textContent="Buy Seal Tag";
  buySeal.onclick=()=>{
    if(state.gold>=25){ state.gold-=25; state.sealTags++; text.textContent="Bought 1 Seal Tag."; renderAll(); }
    else text.textContent="Not enough gold.";
  };

  const buyPotion=document.createElement("button");
  buyPotion.textContent="Buy Potion";
  buyPotion.onclick=()=>{
    if(state.gold>=20){ state.gold-=20; state.potions++; text.textContent="Bought 1 Potion."; renderAll(); }
    else text.textContent="Not enough gold.";
  };

  choices.appendChild(buySeal);
  choices.appendChild(buyPotion);
}

function healParty(free=false){
  if(!free && state.gold<10){ log("You need 10 gold to heal here."); return; }
  if(!free) state.gold-=10;
  state.party.forEach(c=>{ c.hp=c.maxHp; c.chakra=c.maxChakra; });
  log("Your party was fully restored.");
  renderAll();
}

function showParty(){
  renderParty();
  show("partyPanel"); hide("worldPanel"); hide("battlePanel"); hide("dialogPanel");
}
function closeParty(){
  hide("partyPanel");
  if(state.mode==="battle") show("battlePanel");
  else show("worldPanel");
}
function renderParty(){
  const el=document.getElementById("partyList");
  el.innerHTML="";
  state.party.forEach((c,i)=>{
    const card=document.createElement("div");
    card.className="card inset";
    card.style.marginBottom="10px";
    card.innerHTML=`
      <h3>${i===state.activeIndex?"★ ":""}${c.name}${c.hp<=0?" (Fainted)":""}</h3>
      <div>Type: ${c.type} · Lv ${c.level}</div>
      <div class="small">HP ${c.hp}/${c.maxHp}</div>
      <div class="meter"><div class="fill" style="width:${Math.max(0,c.hp/c.maxHp*100)}%"></div></div>
      <div class="small">Chakra ${c.chakra}/${c.maxChakra}</div>
      <div class="meter"><div class="fill chakra" style="width:${Math.max(0,c.chakra/c.maxChakra*100)}%"></div></div>
      <div class="row">
        <button ${i===state.activeIndex||c.hp<=0?"disabled":""} data-swap="${i}">Set Active</button>
        <button ${c.hp<=0||state.potions<=0?"disabled":""} data-potion="${i}" class="good">Use Potion</button>
      </div>
    `;
    el.appendChild(card);
  });
  el.querySelectorAll("[data-swap]").forEach(btn=>{
    btn.onclick=()=>{ state.activeIndex=Number(btn.dataset.swap); renderParty(); renderAll(); };
  });
  el.querySelectorAll("[data-potion]").forEach(btn=>{
    btn.onclick=()=>{
      const i=Number(btn.dataset.potion);
      if(state.potions<=0) return;
      const c=state.party[i];
      c.hp=Math.min(c.maxHp,c.hp+30);
      state.potions--;
      renderParty(); renderAll();
    };
  });
}

function startWildBattle(){
  const pool=["Mist Fox","Stone Ape","Spark Beetle","Wind Hare","Ash Toad"];
  const name=pool[Math.floor(Math.random()*pool.length)];
  startBattle(createCreature(name,3+Math.floor(Math.random()*4)),false);
}
function startTrainerBattle(){ startBattle(createCreature("Stone Ape",7),true,"Trial Trainer"); }
function startRivalBattle(){
  const rival = state.rivalDefeated ? createCreature("Storm Hawk",11) : createCreature("Volt Hawk",9);
  startBattle(rival,true,"Rival Kento");
}

function startBattle(enemy,isTrainer,label=null){
  state.mode="battle";
  state.battle={enemy,isTrainer,label};
  state.stunned=false; state.enemyStunned=false;
  hide("worldPanel"); hide("partyPanel"); hide("dialogPanel"); show("battlePanel");
  document.getElementById("battleLog").textContent="";
  battleLog((label|| (isTrainer?"Trainer":"Wild")) + " " + enemy.name + " appeared!");
  renderBattle();
}

function typeModifier(moveType,targetType){
  const row=typeChart[moveType] || typeChart.Neutral;
  if(row.strong.includes(targetType)) return 1.5;
  if(row.weak.includes(targetType)) return 0.75;
  return 1;
}
function statWithBuff(base,buff){ return Math.max(1,Math.floor(base*(1+buff*0.2))); }
function calcDamage(attacker,defender,move){
  if(move.power<=0) return 0;
  let dmg=Math.floor(((statWithBuff(attacker.attack,attacker.buffs.attack) / statWithBuff(defender.defense,defender.buffs.defense)) * move.power)/2.2);
  dmg=Math.max(1,dmg);
  dmg=Math.floor(dmg * typeModifier(move.type,defender.type));
  if(move.effect==="crit20" && Math.random()<0.2) dmg=Math.floor(dmg*1.5);
  return Math.max(1,dmg);
}

function applyMove(user,target,move,isPlayer){
  if(user.chakra<move.cost){ battleLog(user.name + " lacks chakra for " + move.name + "."); return; }
  user.chakra-=move.cost;
  if(move.power>0){
    const dmg=calcDamage(user,target,move);
    target.hp=Math.max(0,target.hp-dmg);
    let text=user.name+" used "+move.name+" for "+dmg+" damage.";
    const mod=typeModifier(move.type,target.type);
    if(mod>1) text+=" It's strong!";
    if(mod<1) text+=" It's resisted.";
    battleLog(text);
    if(move.effect==="stun20" && Math.random()<0.2 && target.hp>0){
      if(isPlayer) state.enemyStunned=true; else state.stunned=true;
      battleLog(target.name+" was stunned!");
    }
  } else {
    if(move.effect==="buff_attack"){ user.buffs.attack++; battleLog(user.name+"'s attack rose."); }
    if(move.effect==="buff_defense"){ user.buffs.defense++; battleLog(user.name+"'s defense rose."); }
    if(move.effect==="buff_speed"){ user.buffs.speed++; battleLog(user.name+"'s speed rose."); }
  }
}

function renderBattle(){
  const p=activeCreature(), e=state.battle.enemy;
  document.getElementById("playerBattleStats").innerHTML=`
    <h3>${p.name} · Lv ${p.level}</h3>
    <div>Type: ${p.type}</div>
    <div class="small">HP ${p.hp}/${p.maxHp}</div>
    <div class="meter"><div class="fill" style="width:${p.hp/p.maxHp*100}%"></div></div>
    <div class="small">Chakra ${p.chakra}/${p.maxChakra}</div>
    <div class="meter"><div class="fill chakra" style="width:${p.chakra/p.maxChakra*100}%"></div></div>
  `;
  document.getElementById("enemyBattleStats").innerHTML=`
    <h3>${e.name} · Lv ${e.level}</h3>
    <div>Type: ${e.type}</div>
    <div class="small">HP ${e.hp}/${e.maxHp}</div>
    <div class="meter"><div class="fill enemy" style="width:${e.hp/e.maxHp*100}%"></div></div>
    <div class="small">Chakra ${e.chakra}/${e.maxChakra}</div>
    <div class="meter"><div class="fill chakra" style="width:${e.chakra/e.maxChakra*100}%"></div></div>
  `;

  const actions=document.getElementById("battleActions");
  actions.innerHTML="";
  p.moves.forEach((move,i)=>{
    const b=document.createElement("button");
    b.textContent=`${move.name} (${move.cost})`;
    b.onclick=()=>playerTurn(i);
    actions.appendChild(b);
  });

  const seal=document.createElement("button");
  seal.className="good";
  seal.textContent=`Seal Tag (${state.sealTags})`;
  seal.disabled=state.battle.isTrainer || state.sealTags<=0;
  seal.onclick=tryCapture;
  actions.appendChild(seal);

  const potion=document.createElement("button");
  potion.className="warn";
  potion.textContent=`Potion (${state.potions})`;
  potion.disabled=state.potions<=0;
  potion.onclick=useBattlePotion;
  actions.appendChild(potion);
}

function playerTurn(moveIndex){
  const p=activeCreature(), e=state.battle.enemy, move=p.moves[moveIndex];
  if(statWithBuff(p.speed,p.buffs.speed) >= statWithBuff(e.speed,e.buffs.speed)){
    runActorTurn(true,move);
    if(e.hp>0) enemyTurn();
  } else {
    enemyTurn();
    if(p.hp>0) runActorTurn(true,move);
  }
  checkBattleEnd();
  renderBattle();
  renderAll();
}

function runActorTurn(isPlayer,selectedMove=null){
  const actor=isPlayer?activeCreature():state.battle.enemy;
  const target=isPlayer?state.battle.enemy:activeCreature();
  if(isPlayer && state.stunned){ battleLog(actor.name+" is stunned."); state.stunned=false; return; }
  if(!isPlayer && state.enemyStunned){ battleLog(actor.name+" is stunned."); state.enemyStunned=false; return; }
  let move=selectedMove;
  if(!isPlayer){
    const usable=actor.moves.filter(m=>actor.chakra>=m.cost);
    move=(usable.length?usable[Math.floor(Math.random()*usable.length)]:actor.moves[0]);
  }
  applyMove(actor,target,move,isPlayer);
}
function enemyTurn(){ if(state.battle.enemy.hp>0) runActorTurn(false); }

function tryCapture(){
  if(state.battle.isTrainer || state.sealTags<=0) return;
  state.sealTags--;
  const e=state.battle.enemy;
  const chance=Math.min(88, Math.floor(((e.maxHp-e.hp)/e.maxHp)*100)+25);
  if(Math.random()*100 < chance){
    if(state.party.length<6){
      state.party.push(e);
      state.captured++;
      state.quests.catchOne=true;
      battleLog("Seal successful! "+e.name+" joined your party.");
      endBattle(true,true);
    } else {
      battleLog("Seal worked, but your party is full.");
      endBattle(true,false);
    }
  } else {
    battleLog("The seal tag failed!");
    enemyTurn();
    checkBattleEnd();
    renderBattle();
  }
}

function useBattlePotion(){
  if(state.potions<=0) return;
  const p=activeCreature();
  p.hp=Math.min(p.maxHp,p.hp+30);
  state.potions--;
  battleLog(p.name+" recovered 30 HP.");
  enemyTurn();
  checkBattleEnd();
  renderBattle();
  renderAll();
}

function grantExp(c,amt){
  c.exp += amt;
  while(c.exp >= 25){
    c.exp -= 25;
    c.level++;
    c.maxHp += 5; c.maxChakra += 3; c.attack += 2; c.defense += 2; c.speed += 2;
    c.hp=c.maxHp; c.chakra=c.maxChakra;
    log(c.name+" reached level "+c.level+"!");
    checkEvolution(c);
  }
}

function checkEvolution(c){
  const base=creaturesData[c.name];
  if(base && base.evolvesTo && c.level >= base.evolveLevel){
    const evoName=base.evolvesTo;
    const evoData=creaturesData[evoName];
    c.name=evoName;
    c.type=evoData.type;
    c.maxHp=Math.max(c.maxHp,evoData.maxHp + (c.level-5)*4);
    c.maxChakra=Math.max(c.maxChakra,evoData.maxChakra + (c.level-5)*2);
    c.attack=Math.max(c.attack,evoData.attack + (c.level-5)*2);
    c.defense=Math.max(c.defense,evoData.defense + (c.level-5)*2);
    c.speed=Math.max(c.speed,evoData.speed + (c.level-5)*2);
    c.hp=c.maxHp; c.chakra=c.maxChakra;
    c.moves=deepClone(evoData.moves);
    log("Evolution! Your beast became "+evoName+"!");
  }
}

function checkBattleEnd(){
  const p=activeCreature(), e=state.battle.enemy;
  if(e.hp<=0){ endBattle(true,false); return; }
  if(p.hp<=0){
    const next=state.party.findIndex(c=>c.hp>0);
    if(next!==-1){ state.activeIndex=next; battleLog(state.party[next].name+" steps in!"); }
    else endBattle(false,false);
  }
}

function endBattle(win,captured){
  const enemy=state.battle.enemy;
  const label=state.battle.label;
  const trainer=state.battle.isTrainer;
  state.mode="world";
  state.battle=null;
  hide("battlePanel"); show("worldPanel");

  if(win){
    if(!captured){
      log(enemy.name+" was defeated.");
      grantExp(activeCreature(), trainer?18:12);
    }
    if(trainer){
      state.gold += 40;
      if(label==="Trial Trainer"){ state.trainerDefeated=true; state.quests.beatTrainer=true; log("You beat the trial trainer and earned 40 gold."); }
      else if(label==="Rival Kento"){ state.rivalDefeated=true; state.quests.beatRival=true; log("You defeated Rival Kento and earned 40 gold."); }
    } else {
      state.gold += 8;
    }
  } else {
    log("You lost the battle. Your active beast was restored.");
    activeCreature().hp=activeCreature().maxHp;
    activeCreature().chakra=activeCreature().maxChakra;
  }
  renderAll();
}

function renderActiveStats(){
  const c=activeCreature();
  if(!c) return;
  document.getElementById("activeStats").innerHTML=`
    <div><strong>${c.name}</strong> · ${c.type} · Lv ${c.level}</div>
    <div class="small">EXP ${c.exp}/25</div>
    <div class="small">HP ${c.hp}/${c.maxHp}</div>
    <div class="meter"><div class="fill" style="width:${c.hp/c.maxHp*100}%"></div></div>
    <div class="small">Chakra ${c.chakra}/${c.maxChakra}</div>
    <div class="meter"><div class="fill chakra" style="width:${c.chakra/c.maxChakra*100}%"></div></div>
    <div class="small">Atk ${c.attack} · Def ${c.defense} · Spd ${c.speed}</div>
  `;
}
function renderProgress(){
  document.getElementById("progressStats").innerHTML=`
    <div>Gold: <strong>${state.gold}</strong></div>
    <div>Seal Tags: <strong>${state.sealTags}</strong></div>
    <div>Potions: <strong>${state.potions}</strong></div>
    <div>Captured: <strong>${state.captured}</strong></div>
    <div>Party: <strong>${state.party.length}</strong>/6</div>
  `;
}
function renderQuests(){
  const q=state.quests;
  const line=(done,text)=>`<div class="${done?"quest-done":"quest-open"}">${done?"✔":"•"} ${text}</div>`;
  document.getElementById("questStats").innerHTML = [
    line(q.talkSensei,"Talk to Sensei Riku"),
    line(q.catchOne,"Catch one Chakra Beast"),
    line(q.beatTrainer,"Defeat the trial trainer"),
    line(q.beatRival,"Defeat Rival Kento")
  ].join("");
}

function renderAll(){
  drawMap();
  if(state.started){
    renderActiveStats();
    renderProgress();
    renderQuests();
    if(state.mode==="battle" && state.battle) renderBattle();
  }
}

function saveGame(){
  localStorage.setItem(SAVE_KEY, JSON.stringify(state));
  log("Game saved.");
}
function loadGame(){
  const raw=localStorage.getItem(SAVE_KEY);
  if(!raw){ log("No save found."); return; }
  state=JSON.parse(raw);
  hide("starterPanel"); show("gameUI");
  hide("partyPanel"); hide("dialogPanel");
  if(state.mode==="battle" && state.battle) show("battlePanel"); else { state.mode="world"; hide("battlePanel"); show("worldPanel"); }
  log("Game loaded.");
  renderAll();
}

renderAll();
</script>
